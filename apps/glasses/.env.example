# Frontend build (glasses webview)
# Put this in .env.production (gitignored, not this file) with the deployed
# Lambda's Function URL (apps/server/terraform/outputs.tf → function_url), so
# `pnpm build` bakes it into the packaged app. Vite only loads .env.production
# for `vite build`, not `vite dev`, so local dev keeps using the proxy in
# vite.config.ts regardless of what's set there.
VITE_API_BASE=

# Dev-only auto-fill for the Notion settings form (src/tenant-config.ts,
# getDevEnvConfig). When all of these are set, `pnpm dev` skips the manual
# settings prompt and uses them directly — handy when testing against the
# evenhub-simulator so you don't re-enter your token/DB IDs every run. Only
# read when import.meta.env.DEV is true, so these never affect a packaged
# build even though .env.local also loads for `vite build`. Fill in your own
# values in .env.local (gitignored) — leave blank here.
VITE_NOTION_TOKEN=
VITE_NOTION_TASKS_DB=
VITE_NOTION_NOTES_DB=
VITE_NOTION_PROJECTS_DB=
VITE_NOTION_TAGS_DB=
