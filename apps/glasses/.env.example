# Frontend build (glasses webview)
# Put this in .env.production (gitignored, not this file) with the deployed
# Lambda's Function URL (apps/server/terraform/outputs.tf → function_url), so
# `pnpm build` bakes it into the packaged app. Vite only loads .env.production
# for `vite build`, not `vite dev`, so local dev keeps using the proxy in
# vite.config.ts regardless of what's set there.
VITE_API_BASE=
