{
  "name": "@notion-ub/server",
  "version": "2.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/express/index.ts",
    "build": "esbuild src/lambda/handler.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist-lambda/index.js && echo '{\"type\":\"commonjs\"}' > dist-lambda/package.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "tf:init": "terraform -chdir=terraform init",
    "tf:plan": "pnpm build && terraform -chdir=terraform plan",
    "tf:apply": "pnpm build && terraform -chdir=terraform apply"
  },
  "dependencies": {
    "@notion-ub/contracts": "workspace:*",
    "@notionhq/client": "^2.2.15",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@notion-ub/typescript-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
