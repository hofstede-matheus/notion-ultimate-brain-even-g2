# Server
# Notion credentials are no longer server env config — each user enters their
# own token + database IDs in the app's Settings screen (see src/tenant-config.ts).
PORT=3210

# Frontend build (glasses webview)
# Put this in .env.production (gitignored, not this file/.env) with the
# deployed Lambda's Function URL (terraform/outputs.tf → function_url), so
# `npm run build` bakes it into the packaged app. Vite only loads
# .env.production for `vite build`, not `vite dev`, so local dev keeps using
# the proxy in vite.config.ts regardless of what's set there.
VITE_API_BASE=
